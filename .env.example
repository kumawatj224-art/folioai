# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
# Default deploy-safe value. Keep false in Vercel until MVP1 is ready.
ENABLE_NEW_APP=false

# Google OAuth
# Add http://localhost:3000/api/auth/callback/google and your Vercel production callback URL in Google Cloud Console.
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Vercel Deploy API
VERCEL_API_TOKEN=replace-me
VERCEL_TEAM_ID=optional-team-id
